{
  "name": "inversify-props",
  "version": "3.0.0",
  "description": "Wrapper to use inversify as property decorator with TypeScript, useful for component libraries like Vue, React or LitElement",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": "Quique Fdez Guerra",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CKGrafico/inversify-props.git"
  },
  "keywords": [
    "inversify",
    "inversifyjs",
    "typescript",
    "dependency injection",
    "typescript di",
    "react di",
    "vue di",
    "vue inject",
    "react inject",
    "litelement"
  ],
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "inversify": "^8.1.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
